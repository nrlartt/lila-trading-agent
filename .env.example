# Trust Wallet Agent Kit
# Get Access ID and HMAC Secret from https://portal.trustwallet.com
TWAK_ACCESS_ID=your_twak_access_id
TWAK_HMAC_SECRET=your_twak_hmac_secret
TWAK_WALLET_PASSWORD=LilaAgentSecure123!

# CoinMarketCap AI Agent Hub (MCP)
# API Key from https://pro.coinmarketcap.com (sent as X-CMC-MCP-API-KEY header)
CMC_MCP_API_KEY=your_cmc_api_key
# MCP server endpoint (Streamable HTTP). Override only if CMC changes it.
CMC_MCP_URL=https://mcp.coinmarketcap.com/mcp

# AI (Groq LLM)
# API Key for Groq
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Agent Configuration
AGENT_MODE=paper              # paper | live
TRADE_INTERVAL_MS=300000      # 5 minutes in milliseconds

# x402 Micropayments — consumer side (self-funding premium data/compute via TWAK)
X402_ENABLED=true             # true | false
# Optional x402-gated intelligence endpoint the agent pays per request.
# Leave blank to use the built-in simulated premium feed.
X402_DATA_ENDPOINT=

# x402 Alpha-as-a-Service — seller side (LILA sells its own intelligence)
X402_SELL_ENABLED=true        # expose paid /skill/market-read endpoint
X402_SELL_PRICE_USD=0.01      # price per request in USDC
X402_NETWORK=bsc              # settlement network
USDC_ADDRESS=0x8AC76a51cc950d9822D68b83FE1ad97B32CD580d   # USDC (Binance-Peg) on BSC
USDC_DECIMALS=18
# Optional x402 facilitator for live verify/settle. Blank = simulated settlement.
X402_FACILITATOR_URL=
# Public base URL advertised in payment requirements (resource URL)
PUBLIC_BASE_URL=http://localhost:3000
STARTING_BALANCE_USD=10       # Starting virtual or real capital
MAX_DRAWDOWN_PCT=10           # Max drawdown percentage (10%)
DAILY_LIMIT_USD=10            # Daily cumulative limit in USD ($10)
MAX_TRADE_USD=5               # Max per-trade limit in USD ($5)
SLIPPAGE_BPS=100              # Slippage: 100 bps (1%)

# BNB Chain Config
BSC_RPC_URL=https://bsc-dataseed.binance.org
BSC_CHAIN_ID=56

# Server Config
PORT=3000
DASHBOARD_WS_PORT=3001
